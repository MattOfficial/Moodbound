# --- Database Credentials ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vibe_novel_db

# --- Neo4j Credentials ---
# Format: username/password
NEO4J_USER=neo4j
NEO4J_PASSWORD=vibe_password

# --- API Keys ---

# Global fallback (Sets the provider for both Embeddings and LLM if not specified below)
AI_PROVIDER=gemini

# You can mix and match providers by prefixing the model with 'provider/'
# Example: Use DeepSeek for fast generation + OpenAI for high-quality embeddings
# EMBEDDING_MODEL=openai/text-embedding-3-small
# FAST_LLM_MODEL=deepseek/deepseek-chat
# EMBED_BATCH_SIZE=32
# EMBEDDING_MAX_CHARS=8000
# EMBEDDING_SPLIT_OVERLAP_CHARS=400
# EMBED_RECOVERY_BATCH_SIZE=20

# --- Provider Credentials ---

# Inject these at runtime (shell/secret manager). Keep them empty in committed files.

# Gemini API Key
GOOGLE_API_KEY=

# OpenAI API Key
OPENAI_API_KEY=

# DeepSeek API Key
DEEPSEEK_API_KEY=
