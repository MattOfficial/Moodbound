# --- Database Credentials ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vibe_novel_db

# --- Neo4j Credentials ---
# Format: username/password
NEO4J_USER=neo4j
NEO4J_PASSWORD=vibe_password

# --- AI Provider Selection ---
# Options: gemini, openai
AI_PROVIDER=gemini

# --- API Keys ---
# Provide the key corresponding to your chosen AI_PROVIDER
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Model Selection (Optional Overrides) ---
# For Gemini: text-embedding-004, gemini-1.5-flash, gemini-1.5-pro
# For OpenAI: text-embedding-3-small, gpt-4o-mini, gpt-4o
# Leave commented out to use defaults based on your AI_PROVIDER
EMBEDDING_MODEL=text-embedding-004
FAST_LLM_MODEL=gemini-1.5-flash
THINKING_LLM_MODEL=gemini-1.5-pro
